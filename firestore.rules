rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Helper Functions ---
    
    // Check if the request is from an authenticated user
    function isAuthenticated() {
      return request.auth != null;
    }

    // Check if the authenticated user has the 'admin' role
    function isAdmin() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Check if the authenticated user is the author of the document
    function isOwner(authorId) {
      return isAuthenticated() && request.auth.uid == authorId;
    }

    // --- Collection Rules ---

    // Users Collection: Users can manage their own profile; admins can read all profiles.
    match /users/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
      allow read: if isAdmin();
    }

    // Courses Collection: Publicly readable; Admin only write/update/delete.
    match /courses/{courseId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Announcements Collection: Publicly readable; Admin only write/update/delete.
    match /announcements/{announcementId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Forum Threads: Authenticated users can read and create; only authors can update or delete.
    match /forum_threads/{threadId} {
      allow read, create: if isAuthenticated();
      allow update, delete: if isOwner(resource.data.authorId);

      // Nested Replies Subcollection: Same authentication and authorship logic.
      match /replies/{replyId} {
        allow read, create: if isAuthenticated();
        allow update, delete: if isOwner(resource.data.authorId);
      }
    }
  }
}