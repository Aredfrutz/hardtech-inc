
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // --- Prototype Rules: Highly Permissive ---
    // Since we are using a custom mock auth for the prototype UI, 
    // we allow public access to facilitate development and testing.
    
    match /{document=**} {
      allow read, write: if true;
    }
    
    // In a production environment, you would revert to strict rules 
    // using Firebase Auth and user role documents.
  }
}
