
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper to ensure documentation is comprehensive before publishing
    function isCourseComprehensive(data) {
      return data.keys().hasAll(['title', 'description', 'modules', 'fees', 'status']) &&
             data.modules.size() > 0 &&
             data.fees.tuition >= 0 &&
             (data.status == 'Active' || data.status == 'Upcoming' || data.status == 'Draft' || data.status == 'Archived');
    }

    function isOfficialComprehensive(data) {
      return data.keys().hasAll(['name', 'position', 'bio', 'certifications']) &&
             data.certifications.size() > 0 &&
             data.bio.size() > 50;
    }

    match /courses/{courseId} {
      allow read: if true;
      allow write: if isCourseComprehensive(request.resource.data);
    }

    match /officials/{officialId} {
      allow read: if true;
      allow write: if isOfficialComprehensive(request.resource.data);
    }

    match /users/{userId} {
      allow read, write: if true;
    }

    match /announcements/{id} {
      allow read: if true;
      allow write: if true;
    }

    match /forum_threads/{id} {
      allow read: if true;
      allow write: if true;
      match /replies/{rid} {
        allow read, write: if true;
      }
    }

    match /public_forms/{id} {
      allow read: if true;
      allow write: if true;
    }

    match /certificate_requests/{id} {
      allow read, write: if true;
    }

    match /{document=**} {
      allow read, write: if true;
    }
  }
}
