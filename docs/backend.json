
{
  "entities": {
    "Course": {
      "title": "Technical Training Course",
      "description": "A comprehensive training program with syllabus, faculty, and logistics.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "summary": { "type": "string" },
        "description": { "type": "string" },
        "ncLevel": { "type": "string", "description": "TESDA NC Level if applicable" },
        "durationHours": { "type": "number" },
        "instructorIds": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string", "enum": ["Active", "Draft", "Archived"] },
        "imageId": { "type": "string" },
        "modules": { 
          "type": "array", 
          "items": { 
            "type": "object", 
            "properties": {
              "day": { "type": "string" },
              "topic": { "type": "string" },
              "details": { "type": "string" }
            }
          } 
        },
        "prerequisites": { "type": "array", "items": { "type": "string" } },
        "requiredTools": { "type": "array", "items": { "type": "string" } },
        "fees": {
          "type": "object",
          "properties": {
            "tuition": { "type": "number" },
            "materials": { "type": "number" },
            "total": { "type": "number" }
          }
        },
        "faqs": { 
          "type": "array", 
          "items": { 
            "type": "object", 
            "properties": {
              "question": { "type": "string" },
              "answer": { "type": "string" }
            }
          } 
        }
      },
      "required": ["title", "description", "modules", "fees", "status"]
    },
    "User": {
      "title": "User Profile",
      "description": "User account details and permissions.",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["student", "admin"] }
      },
      "required": ["email", "role"]
    },
    "Official": {
      "title": "Academy Official",
      "description": "Leadership and staff members of the center.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "position": { "type": "string" },
        "department": { "type": "string" },
        "email": { "type": "string" },
        "bio": { "type": "string" },
        "certifications": { "type": "array", "items": { "type": "string" } },
        "imageId": { "type": "string" }
      },
      "required": ["name", "position", "bio", "certifications"]
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "/courses/{courseId}": {
      "schema": "Course",
      "description": "Collection of official training programs."
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "System users and their roles."
    },
    "/officials/{officialId}": {
      "schema": "Official",
      "description": "Directory of staff with comprehensive bios and certifications."
    }
  }
}
