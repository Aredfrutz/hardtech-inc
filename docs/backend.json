
{
  "entities": {
    "Course": {
      "title": "Training Course",
      "description": "A technical training course offered by HardTech Academy.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "instructor": { "type": "string" },
        "duration": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "Draft", "Archived"] },
        "imageId": { "type": "string" }
      },
      "required": ["title", "description", "instructor", "status"]
    },
    "User": {
      "title": "User Profile",
      "description": "User account details and permissions.",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["student", "admin"] }
      },
      "required": ["email", "role"]
    },
    "Announcement": {
      "title": "Official Announcement",
      "description": "Administrative updates and news for the academy.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "body": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "priority": { "type": "string", "enum": ["Low", "Medium", "High"] }
      },
      "required": ["title", "body", "timestamp"]
    },
    "ForumThread": {
      "title": "Forum Discussion Thread",
      "description": "User-generated discussion threads in the public forum.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "authorId", "authorName", "createdAt"]
    },
    "ForumReply": {
      "title": "Forum Reply",
      "description": "User responses within a forum thread.",
      "type": "object",
      "properties": {
        "content": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["content", "authorId", "authorName", "createdAt"]
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "/courses/{courseId}": {
      "schema": "Course",
      "description": "Collection of official training courses."
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "System users and their roles."
    },
    "/announcements/{announcementId}": {
      "schema": "Announcement",
      "description": "Collection of administrative announcements."
    },
    "/forum_threads/{threadId}": {
      "schema": "ForumThread",
      "description": "Top-level forum discussion threads."
    },
    "/forum_threads/{threadId}/replies/{replyId}": {
      "schema": "ForumReply",
      "description": "Nested replies for a specific thread."
    }
  }
}
